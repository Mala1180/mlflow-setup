# MLFlow
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI="http://127.0.0.1:${MLFLOW_PORT}"
MLFLOW_SECRET_KEY=secret_key
MLFLOW_ADMIN_USER=admin
MLFLOW_ADMIN_PASSWORD=adminpassword # at least 12 characters

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mlflow_db
POSTGRES_PORT=5432
POSTGRES_CONTAINER=mlflow-db

# MinIO
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=password
MINIO_CONTAINER=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MLFLOW_S3_ENDPOINT_URL="http://${MINIO_CONTAINER}:${MINIO_PORT}"
MINIO_MLFLOW_BUCKET=mlflow-bucket

# list of users to insert at startup (starting with USER_)
USER_1=john
USER_1_PASSWORD=johnpassword123

USER_2=mario
USER_2_PASSWORD=mariopassword123